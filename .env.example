# ─── LLM Configuration ────────────────────────────────────────────────────────
# Provider: openai | anthropic | google
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# ─── API Keys ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...

# ─── Transcription ────────────────────────────────────────────────────────────
# Transcription backend: openai_whisper | local_whisper
TRANSCRIPTION_BACKEND=openai_whisper
# Only used when TRANSCRIPTION_BACKEND=local_whisper
# LOCAL_WHISPER_MODEL=base

# ─── Storage ──────────────────────────────────────────────────────────────────
CONFIGS_DIR=configs
LOGS_DIR=logs
CASES_DIR=cases
